# Lard - Environment Variables Template
# ------------------------------------
# Copy this file to .env and adjust as needed.

# ── 📂 DATA STORAGE ──
# Main directory for all persistent data (DB, Uploads, Vectors, Models)
# LARD_DATA_DIR=/app/data

# Individual overrides (Optional: Defaults to subfolders of LARD_DATA_DIR)
# LARD_DB_DIR=
# LARD_UPLOADS_DIR=
# LARD_CHROMA_DIR=
# LARD_HF_HOME=

# ── 🧠 LOCAL AI (OLLAMA) ──
# Use http://host.docker.internal:11434 on Linux/Docker to reach host
LARD_OLLAMA_BASE_URL=http://host.docker.internal:11434
LARD_OLLAMA_MODEL=gemma3:4b-it-qat

# ── ☁️ CLOUD AI PROVIDERS (OPTIONAL) ──
LARD_OPENAI_API_KEY=
LARD_ANTHROPIC_API_KEY=

# ── 🚀 NETWORK / DOCKER ──
# Internal URL for the Next.js Proxy to reach the FastAPI backend
INTERNAL_BACKEND_URL=http://backend:8000

# Port for the frontend (Mapped in docker-compose)
FRONTEND_PORT=8081
