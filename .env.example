# Lard - Environment Variables Template

# Backend Configuration
# ---------------------
# Database URL (Default for Docker is /app/tracker.db)
DATABASE_URL=sqlite:////app/tracker.db

# Ollama Access (Required for local AI)
# Use http://host.docker.internal:11434 on Linux/Windows/Mac to reach Ollama on the host
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Provider Keys (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend Configuration
# ----------------------
# Internal URL for the Next.js Proxy to reach the FastAPI backend
INTERNAL_BACKEND_URL=http://backend:8000

# Port for the frontend (Mapped in docker-compose)
FRONTEND_PORT=8081
