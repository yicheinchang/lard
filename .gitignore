# Monorepo .gitignore for Job Tracker (Next.js & FastAPI)

# Persistence (Template structure only, no content)
data/**
!data/**/
!data/**/.gitkeep

# Legacy/Temporary (Consolidated migration)
backend/*.old
backend/*.old.db
backend/uploads.old/
backend/chroma_db.old/

# Backend
backend/__pycache__/
backend/*.py[oc]
backend/build/
backend/dist/
backend/wheels/
backend/*.egg-info
backend/.venv/
backend/*.log
backend/app_settings.json
backend/test/
backend/tmp/

# Frontend
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
frontend/coverage/
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/*.log
