# Monorepo .gitignore for Job Tracker (Next.js & FastAPI)

# Common
.DS_Store
.env*
*.log
*.bak

# Backend
backend/__pycache__/
backend/*.py[oc]
backend/build/
backend/dist/
backend/wheels/
backend/*.egg-info
backend/.venv/
backend/tracker.db
backend/uploads/
backend/*.log

# Frontend
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
frontend/coverage/
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/*.log
